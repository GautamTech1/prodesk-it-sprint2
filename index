<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cash Flow - Salary & Expense Tracker</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <link rel="stylesheet" href="styles.css">
</head>
<body class="bg-gray-100 min-h-screen">
    <div class="container mx-auto px-4 py-8 max-w-6xl">
        <h1 class="text-4xl font-bold text-center text-gray-800 mb-8">Cash Flow - Salary & Expense Tracker</h1>
        
        <!-- Threshold Alert Banner -->
        <div id="thresholdAlert" class="hidden bg-red-100 border-l-4 border-red-500 text-red-700 p-4 mb-6">
            <p class="font-bold">⚠️ Critical Warning: Remaining Balance is below 10% of Total Salary!</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Left Column: Forms & Summary -->
            <div class="lg:col-span-2 space-y-6">
                <!-- Salary Input -->
                <div class="bg-white rounded-xl shadow-md p-6">
                    <h2 class="text-2xl font-semibold text-gray-700 mb-4">Total Salary</h2>
                    <div class="flex gap-4">
                        <input 
                            type="number" 
                            id="salaryInput" 
                            placeholder="Enter your total salary"
                            class="flex-1 px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-blue-500"
                        >
                        <button 
                            id="setSalaryBtn"
                            class="px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors"
                        >
                            Set Salary
                        </button>
                    </div>
                </div>

                <!-- Expense Input -->
                <div class="bg-white rounded-xl shadow-md p-6">
                    <h2 class="text-2xl font-semibold text-gray-700 mb-4">Add Expense</h2>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <input 
                            type="text" 
                            id="expenseName" 
                            placeholder="Expense name"
                            class="px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-blue-500"
                        >
                        <input 
                            type="number" 
                            id="expenseAmount" 
                            placeholder="Amount"
                            class="px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-blue-500"
                        >
                        <button 
                            id="addExpenseBtn"
                            class="px-6 py-3 bg-green-600 text-white font-semibold rounded-lg hover:bg-green-700 transition-colors"
                        >
                            Add Expense
                        </button>
                    </div>
                    <div id="errorMessage" class="hidden text-red-500 mt-4 font-semibold"></div>
                </div>

                <!-- Summary Cards -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div class="bg-blue-500 text-white rounded-xl shadow-md p-6">
                        <h3 class="text-lg font-medium opacity-90">Total Salary</h3>
                        <p class="text-3xl font-bold" id="totalSalaryDisplay">₹0</p>
                    </div>
                    <div class="bg-red-500 text-white rounded-xl shadow-md p-6">
                        <h3 class="text-lg font-medium opacity-90">Total Expenses</h3>
                        <p class="text-3xl font-bold" id="totalExpensesDisplay">₹0</p>
                    </div>
                    <div class="bg-green-500 text-white rounded-xl shadow-md p-6">
                        <h3 class="text-lg font-medium opacity-90">Remaining Balance</h3>
                        <p class="text-3xl font-bold" id="remainingBalanceDisplay">₹0</p>
                    </div>
                </div>

                <!-- Expenses List -->
                <div class="bg-white rounded-xl shadow-md p-6">
                    <div class="flex justify-between items-center mb-4">
                        <h2 class="text-2xl font-semibold text-gray-700">Expenses</h2>
                        <div class="flex gap-3">
                            <button 
                                id="currencyToggleBtn"
                                class="px-4 py-2 bg-purple-600 text-white font-semibold rounded-lg hover:bg-purple-700 transition-colors"
                            >
                                Switch to USD
                            </button>
                            <button 
                                id="downloadPdfBtn"
                                class="px-4 py-2 bg-orange-600 text-white font-semibold rounded-lg hover:bg-orange-700 transition-colors"
                            >
                                Download Report
                            </button>
                        </div>
                    </div>
                    <ul id="expensesList" class="space-y-3">
                        <!-- Expenses will be rendered here -->
                    </ul>
                </div>
            </div>

            <!-- Right Column: Chart -->
            <div class="lg:col-span-1">
                <div class="bg-white rounded-xl shadow-md p-6 sticky top-8">
                    <h2 class="text-2xl font-semibold text-gray-700 mb-4">Financial Overview</h2>
                    <canvas id="expenseChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <script src="app.js"></script>
</body>
</html>
